<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="100dp"
    android:paddingHorizontal="30dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Elementos de selección"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:drawableStartCompat="@drawable/seleccion" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Los elementos de selección son componentes de interfaz que permiten al usuario elegir opciones, alternar estados o ajustar magnitudes de forma intuitiva. Sirven para capturar entradas de datos precisas sin necesidad de escribir. Es conveniente usarlos para simplificar formularios, configurar preferencias del sistema o seleccionar parámetros dentro de un rango."
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:padding="10dp"
        android:background="@color/black"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp" />

    <CheckBox
        android:id="@+id/checkBoxDivertido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Te gusta esta app?"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elige tu opción favorita:"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/radioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radioOpcion1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="Opción divertida 1" />

        <RadioButton
            android:id="@+id/radioOpcion2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="Opción divertida 2" />
    </LinearLayout>

    <Switch
        android:id="@+id/switchDivertido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activar modo procrastinador"
        android:textColor="@color/black"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnAbrirActivityS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abrir en nueva activity"
        android:textSize="16sp"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="16dp" />
    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textAlignment="center"
        android:text="Da click para ver más ejemplos." />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>